#!/usr/bin/env bash
# cccontainer — launch, watch, stop, enter and fully DRIVE sandboxed Claude Code
# containers. Each container runs a fresh, signed-in Claude Code (vanilla login form).
# Batteries included: control the live session, read its screen, run headless prompts,
# exec anything inside. Thin wrappers over `docker` + `hd` (herdr) — no new deps.
set -u
export PATH="/opt/homebrew/bin:$PATH"

# resolve this script's real dir (works through the ~/.local/bin symlink)
SELF="${BASH_SOURCE[0]}"; while [ -L "$SELF" ]; do SELF="$(readlink "$SELF")"; done
DIR="$(cd "$(dirname "$SELF")" && pwd)"
IDENTIFY="$HOME/.claude/skills/identify/identify.py"

die(){ echo "cccontainer: $*" >&2; exit 1; }

# --- helpers -----------------------------------------------------------------
_cid(){ docker ps -q --filter "label=ccc=1" --filter "name=^$1$" | head -1; }
_lbl(){ docker inspect -f "{{ index .Config.Labels \"$2\" }}" "$1" 2>/dev/null; }
_need(){ local c; c="$(_cid "$1")"; [ -n "$c" ] || die "no running container '$1' (see: cccontainer ls)"; echo "$c"; }

# --- new: split a pane next to us and boot a signed-in claude container -------
cmd_new(){
  local email name js hs pane newpane
  email="${1:-}"
  [ -n "$email" ] || email="$(python3 -c 'import json,os;print(json.load(open(os.path.expanduser("~/.claude.json")))["oauthAccount"]["emailAddress"])' 2>/dev/null)"
  [ -n "$email" ] || die "no host account signed in and no email given"
  js="$(python3 "$IDENTIFY" 2>/dev/null | head -1)"
  hs="$(printf '%s' "$js"  | python3 -c 'import sys,json;print(json.load(sys.stdin).get("herdr_session") or "")')"
  pane="$(printf '%s' "$js"| python3 -c 'import sys,json;print(json.load(sys.stdin).get("herdr_pane") or "")')"
  [ -n "$hs" ] && [ -n "$pane" ] || die "not inside a herdr pane (identify found none)"

  echo "cccontainer: capturing fresh login for ${email}…"
  ( cd "$HOME/Creations/AccountTracker/SwapAccounts" && ./sa capture >/dev/null 2>&1 ) || true

  newpane="$(hd --session "$hs" pane split "$pane" --direction right --ratio 0.5 --no-focus 2>/dev/null \
            | python3 -c 'import sys,json;print(json.load(sys.stdin)["result"]["pane"]["pane_id"])')"
  [ -n "$newpane" ] || die "pane split failed"
  name="cc-$(printf '%s' "$newpane" | tr -c 'A-Za-z0-9_.-' '-')"
  echo "cccontainer: pane $newpane → container $name"
  hd --session "$hs" pane run "$newpane" \
     "bash '$DIR/launch.sh' '$email' '$name' '$hs' '$newpane'" >/dev/null 2>&1
  echo "cccontainer: launching. watch it in the new pane, or: cccontainer ls"
}

# --- shared: capture host login + stage it for a container -------------------
_resolve_email(){ local e="${1:-}"; [ -n "$e" ] || e="$(python3 -c 'import json,os;print(json.load(open(os.path.expanduser("~/.claude.json")))["oauthAccount"]["emailAddress"])' 2>/dev/null)"; echo "$e"; }
_stage_login(){ # <email> <name> → prints STAGE dir, or empty on failure
  local e="$1" n="$2" log="$HOME/.accounttracker/logins/$1" stage="$HOME/.accounttracker/.stage/$2"
  ( cd "$HOME/Creations/AccountTracker/SwapAccounts" && ./sa capture >/dev/null 2>&1 ) || true
  [ -d "$log" ] || return 1
  rm -rf "$stage"; mkdir -p "$stage"
  cp "$log/.claude/.credentials.json" "$stage/.credentials.json"
  cp "$log/.claude/.claude.json"      "$stage/.claude.json"
  chmod 644 "$stage"/.credentials.json "$stage"/.claude.json
  echo "$stage"
}
_ensure_docker(){ echo "cccontainer: waiting for docker daemon…" >&2; until docker info >/dev/null 2>&1; do sleep 2; done; }
# tmux-enabled image, derived from swapaccounts (built once, cached)
_ensure_tmux_image(){
  docker image inspect cccontainer:latest >/dev/null 2>&1 && return 0
  docker image inspect swapaccounts:latest >/dev/null 2>&1 || die "base image swapaccounts:latest missing (build it in AccountTracker/SwapAccounts)"
  echo "cccontainer: building cccontainer:latest (swapaccounts + tmux)…" >&2
  docker build -t cccontainer:latest - >/dev/null 2>&1 <<'DOCKER'
FROM swapaccounts:latest
USER root
RUN apt-get update && apt-get install -y --no-install-recommends tmux \
 && rm -rf /var/lib/apt/lists/*
USER node
DOCKER
}

# --- tmux: container in the CURRENT shell, Claude in in-container tmux ---------
# Detached container; Claude runs in tmux session 'main'; anyone with docker
# access (this shell OR another sandboxed agent) can attach and drive it.
cmd_tmux(){
  local email name stage
  email="$(_resolve_email "${1:-}")"; [ -n "$email" ] || die "no host account signed in and no email given"
  _ensure_docker; _ensure_tmux_image
  echo "cccontainer: capturing fresh login for ${email}…" >&2
  stage="$(_stage_login "$email" "tmp")" || die "no captured login for $email — run: sa capture"
  name="cc-tmux-$(date +%H%M%S)"
  mv "$HOME/.accounttracker/.stage/tmp" "$HOME/.accounttracker/.stage/$name"
  stage="$HOME/.accounttracker/.stage/$name"
  docker run -d --rm --name "$name" \
    --label ccc=1 --label ccc.kind=tmux --label "ccc.email=$email" \
    -v "$stage:/staging:ro" cccontainer:latest bash -c '
      mkdir -p "$HOME/.claude"
      cp /staging/.credentials.json "$HOME/.claude/.credentials.json"
      cp /staging/.claude.json      "$HOME/.claude.json"
      chmod 600 "$HOME/.claude/.credentials.json"
      tmux new-session -d -s main claude
      exec tmux wait-for ccc_hold   # keep PID 1 alive; never signalled
    ' >/dev/null || die "docker run failed"
  _attach_banner "$name"
  # auto-attach the current shell if interactive
  if [ -t 0 ] && [ -t 1 ]; then
    echo "cccontainer: attaching this shell (detach with Ctrl-b d)…"
    exec docker exec -it "$name" tmux attach -t main
  fi
}

_attach_banner(){
  local n="$1"
  cat <<EOF

┌─ cccontainer '$n' — fresh Claude Code in tmux (session 'main') ───────────────
│ ▶ ENTER IT (one-liner):   docker exec -it $n tmux attach -t main
│                     (or:  ccc attach $n)          detach with Ctrl-b d
│
│ ATTACH & DRIVE from this host:
│   ccc attach $n                             # interactive (Ctrl-b d to detach)
│   docker exec -it $n tmux attach -t main
│
│ DRIVE headless (any agent with docker access, incl. another sandboxed agent):
│   cccontainer screen $n                     # read the live screen
│   cccontainer say    $n "your prompt"       # type + Enter
│   cccontainer key    $n Enter               # send a key
│   docker exec $n tmux capture-pane -pt main # raw read
│   docker exec $n tmux send-keys -t main -l "hi"; docker exec $n tmux send-keys -t main Enter
│
│ From ANOTHER container/agent: give it this docker socket
│   (-v /var/run/docker.sock:/var/run/docker.sock) then run the same commands.
│ STOP: cccontainer stop $n
└───────────────────────────────────────────────────────────────────────────────
EOF
}
cmd_attach(){ local c; c="$(_need "$1")"; docker exec -it "$c" tmux attach -t main; }

# --- observability -----------------------------------------------------------
cmd_ls(){
  local ids; ids="$(docker ps -q --filter label=ccc=1)"
  [ -n "$ids" ] || { echo "(no ccc containers running)"; return; }
  printf '%-18s %-26s %-14s %s\n' NAME ACCOUNT WHERE STATUS
  local c k where; for c in $ids; do
    k="$(_lbl "$c" ccc.kind)"
    if [ "$k" = tmux ]; then where="tmux:main"; else where="$(_lbl "$c" ccc.pane)"; fi
    printf '%-18s %-26s %-14s %s\n' \
      "$(docker inspect -f '{{.Name}}' "$c" | sed 's#^/##')" \
      "$(_lbl "$c" ccc.email)" "$where" \
      "$(docker inspect -f '{{.State.Status}}' "$c")"
  done
}
cmd_watch(){ while true; do clear; date; echo; cmd_ls; sleep "${1:-3}"; done; }
cmd_info(){
  local c; c="$(_need "$1")"
  echo "container : $1  ($c)"
  echo "account   : $(_lbl "$c" ccc.email)"
  echo "pane      : $(_lbl "$c" ccc.hsession):$(_lbl "$c" ccc.pane)"
  echo "version   : $(docker exec "$c" claude --version 2>&1)"
  echo "signed-in : $(docker exec "$c" node -e 'console.log(require("/home/node/.claude.json").oauthAccount.emailAddress)' 2>&1)"
  echo "processes :"; docker top "$c" -o pid,cmd 2>/dev/null | grep -iE 'claude|node|PID' | head
}

# --- drive the live session (kind-aware: herdr pane, or in-container tmux) -----
# tmux-kind containers run Claude in tmux session 'main'; herdr-kind in a herdr pane.
cmd_screen(){ local c k; c="$(_need "$1")"; k="$(_lbl "$c" ccc.kind)"
  if [ "$k" = tmux ]; then docker exec "$c" tmux capture-pane -pt main 2>&1 | tail -n "${2:-40}"
  else hd --session "$(_lbl "$c" ccc.hsession)" pane read "$(_lbl "$c" ccc.pane)" --source "${3:-visible}" --lines "${2:-40}"; fi; }
cmd_send(){ local c k; c="$(_need "$1")"; k="$(_lbl "$c" ccc.kind)"; shift
  if [ "$k" = tmux ]; then docker exec "$c" tmux send-keys -t main -l "$*"
  else hd --session "$(_lbl "$c" ccc.hsession)" pane send-text "$(_lbl "$c" ccc.pane)" "$*"; fi; }
cmd_key(){ local c k; c="$(_need "$1")"; k="$(_lbl "$c" ccc.kind)"; shift
  if [ "$k" = tmux ]; then docker exec "$c" tmux send-keys -t main "$@"
  else hd --session "$(_lbl "$c" ccc.hsession)" pane send-keys "$(_lbl "$c" ccc.pane)" "$@"; fi; }
cmd_say(){ local c k; c="$(_need "$1")"; k="$(_lbl "$c" ccc.kind)"; shift
  if [ "$k" = tmux ]; then docker exec "$c" tmux send-keys -t main -l "$*"; sleep 0.4; docker exec "$c" tmux send-keys -t main Enter
  else hd --session "$(_lbl "$c" ccc.hsession)" pane send-text "$(_lbl "$c" ccc.pane)" "$*"; sleep 0.4; hd --session "$(_lbl "$c" ccc.hsession)" pane send-keys "$(_lbl "$c" ccc.pane)" Enter; fi; }

# --- headless prompt (separate session, JSON result) -------------------------
cmd_ask(){ local c; c="$(_need "$1")"; shift; docker exec -i "$c" claude -p "$*"; }

# --- run anything inside -----------------------------------------------------
cmd_exec(){ local c f=-i; c="$(_need "$1")"; shift; [ "${1:-}" = "--" ] && shift; [ -t 0 ] && f=-it; docker exec $f "$c" "${@:-bash}"; }
cmd_update(){ local c; c="$(_need "$1")"; docker exec -u root "$c" npm i -g @anthropic-ai/claude-code@latest 2>&1 | tail -2; docker exec "$c" claude --version; }
cmd_logs(){ local c; c="$(_need "$1")"; docker logs -f "$c"; }
cmd_stop(){
  if [ "${1:-}" = "all" ]; then docker ps -q --filter label=ccc=1 | xargs -r docker stop; return; fi
  docker stop "$(_need "$1")"
}

# --- copy-paste entry commands (read-only / full shell / by PID) --------------
cmd_enter(){
  local c k hs p pid; c="$(_need "$1")"; k="$(_lbl "$c" ccc.kind)"
  pid="$(docker top "$c" -o pid,cmd 2>/dev/null | awk '/claude/{print $1; exit}')"
  echo "# --- ways into '$1' (container $c) ---"
  echo "# full shell (read-write):"
  echo "docker exec -it $c bash"
  if [ "$k" = tmux ]; then
    echo "# attach the live Claude (interactive, Ctrl-b d to detach):"
    echo "docker exec -it $c tmux attach -t main    # or: cccontainer attach $1"
    echo "# read-only (view without typing):"
    echo "watch -n1 'docker exec $c tmux capture-pane -pt main'   # or: cccontainer screen $1"
  else
    hs="$(_lbl "$c" ccc.hsession)"; p="$(_lbl "$c" ccc.pane)"
    echo "# read-only (live view of the running Claude, cannot type):"
    echo "hd --session $hs pane read $p --source visible"
  fi
  echo "# by PID (Claude pid ${pid:-?} inside the container):"
  echo "docker exec -it $c bash    # then inspect/kill $pid  (e.g. cat /proc/$pid/status)"
}

usage(){ cat <<'EOF'
cccontainer — sandboxed, signed-in Claude Code containers you can fully drive.

  new [email]              split a herdr pane and boot a fresh signed-in Claude Code
  tmux [email]             boot in the CURRENT shell — Claude in in-container tmux,
                           attachable/drivable from anywhere (another agent) via docker
  attach <name>            attach the live Claude (docker exec -it … tmux attach)
  ls                       list running ccc containers
  watch [secs]             live-refresh the list
  info <name>              account, version, pane, processes
  stop <name|all>          stop (and auto-remove) container(s)
  enter <name>             print copy-paste commands: read-only / full shell / PID

  drive the live session:
  screen <name> [lines]    read what the running Claude shows
  send <name> <text>       type text into the session (no Enter)
  say  <name> <text>       type text and press Enter
  key  <name> <keys...>    send keys (Enter, Escape, …)

  batteries:
  ask  <name> <prompt>     headless one-shot prompt (claude -p), JSON out
  exec <name> [-- cmd...]  run any command inside (default: bash)
  update <name>            update Claude Code inside to latest
  logs <name>              follow container stdout
EOF
}

sub="${1:-}"; shift || true
case "$sub" in
  new) cmd_new "$@";; tmux) cmd_tmux "$@";; attach) cmd_attach "$@";;
  ls|list) cmd_ls "$@";; watch) cmd_watch "$@";;
  info) cmd_info "$@";; screen) cmd_screen "$@";; send) cmd_send "$@";;
  say) cmd_say "$@";; key) cmd_key "$@";; ask) cmd_ask "$@";;
  exec) cmd_exec "$@";; update) cmd_update "$@";; logs) cmd_logs "$@";;
  stop) cmd_stop "$@";; enter) cmd_enter "$@";; ""|-h|--help|help) usage;;
  *) die "unknown command '$sub' (see: cccontainer help)";;
esac
